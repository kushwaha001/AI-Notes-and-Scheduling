# ── API base ──────────────────────────────────────────────────
# Same-origin "/api" by default (Vite dev proxy / nginx forwards to the backend).
# The offline build talks to the backend directly:
#   VITE_API_BASE=http://localhost:9000
# VITE_API_BASE=http://localhost:9000

# ── Authentication (v2 — Keycloak / OIDC) ─────────────────────
# Whether auth is on is decided by the BACKEND (GET /auth/config -> auth_enabled),
# so you normally don't need to set anything here. These optional overrides let
# the frontend point at Keycloak without relying on that round-trip:
# VITE_KEYCLOAK_URL=http://localhost:8080
# VITE_KEYCLOAK_REALM=udaan
# VITE_KEYCLOAK_CLIENT_ID=udaan-frontend

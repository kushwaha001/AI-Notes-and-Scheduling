# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udaan_db
DB_USER=postgres
DB_PASSWORD=

# ── Ollama (local LLM/VLM for document extraction) ───────────
# Install from: https://ollama.com/download
# Pull model:   ollama pull gemma3:4b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── AI extraction toggles ────────────────────────────────────
AI_ENABLED=true                 # master switch for document extraction
CONFIDENCE_THRESHOLD=0.7        # fields below this are flagged on the confirm screen

# ── Faster-Whisper STT ────────────────────────────────────────
# Model sizes: tiny / base / small / medium / large-v3
# large-v3 recommended for accuracy; small for speed
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE_TYPE=float16 # float16 (GPU) | int8 (CPU)

# ── Qdrant (vector DB for semantic search) ────────────────────
# Download binary from: https://github.com/qdrant/qdrant/releases
# Run: qdrant.exe
QDRANT_HOST=http://localhost:6333
QDRANT_COLLECTION=udaan_notes

# ── Redis (semantic cache) ────────────────────────────────────
# Windows: use Memurai (https://www.memurai.com) or WSL2 + Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

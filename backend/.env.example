# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udaan_db
DB_USER=postgres
DB_PASSWORD=

# ── Authentication (v2 — Keycloak / OIDC) ─────────────────────
# AUTH_ENABLED=false -> single-user mode (everything owned by the 'default'
# user), no Keycloak needed. Set true to require Keycloak login + per-user data.
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080      # Keycloak base URL, no trailing slash
KEYCLOAK_REALM=udaan
KEYCLOAK_CLIENT_ID=udaan-frontend
KEYCLOAK_VERIFY_AUD=false               # true only if you add an audience mapper

# ── Ollama (local LLM/VLM for document extraction) ───────────
# Install from: https://ollama.com/download
# Pull model:   ollama pull gemma3:4b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
EMBED_MODEL=bge-m3              # embeddings for semantic search / Ask (1024-dim)

# ── AI extraction toggles ────────────────────────────────────
AI_ENABLED=true                 # master switch for document extraction
CONFIDENCE_THRESHOLD=0.7        # fields below this are flagged on the confirm screen

# ── Faster-Whisper STT ────────────────────────────────────────
# distil-large-v3 = English, near large-v3 accuracy, ~10x realtime on GPU.
# GPU needs only the NVIDIA driver (CUDA DLLs ship as wheels, auto-loaded).
# No GPU? -> WHISPER_DEVICE=cpu  WHISPER_COMPUTE_TYPE=int8
# Multilingual? -> WHISPER_MODEL=large-v3-turbo  WHISPER_LANGUAGE=
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE_TYPE=float16 # float16 (GPU) | int8 (CPU)
WHISPER_LANGUAGE=en          # language hint; empty = auto-detect

# ── Qdrant (vector DB for semantic search) ────────────────────
# Download binary from: https://github.com/qdrant/qdrant/releases
# Run: qdrant.exe
QDRANT_HOST=http://localhost:6333
QDRANT_COLLECTION=udaan_notes

# ── Redis (semantic cache) ────────────────────────────────────
# Windows: use Memurai (https://www.memurai.com) or WSL2 + Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

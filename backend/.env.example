# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udaan_db
DB_USER=postgres
DB_PASSWORD=

# ── Authentication (v2 — Keycloak / OIDC) ─────────────────────
# AUTH_ENABLED=false -> single-user mode (everything owned by the 'default'
# user), no Keycloak needed. Set true to require Keycloak login + per-user data.
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080      # Keycloak base URL, no trailing slash
KEYCLOAK_REALM=udaan
KEYCLOAK_CLIENT_ID=udaan-frontend
KEYCLOAK_VERIFY_AUD=false               # true only if you add an audience mapper

# ── LLM (document/voice extraction + RAG) ─────────────────────
# OpenAI-compatible API: works with vLLM, Ollama (its /v1 endpoint), TEI, etc.
# Point LLM_BASE_URL at your server, INCLUDING the /v1 suffix.
#   vLLM example:   http://OFFICE-LLM:8000/v1
#   Ollama local:   http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
# Model id the server serves (vLLM --served-model-name). LEAVE BLANK to auto-pick
# the first model the server reports at /v1/models.
LLM_MODEL=
LLM_API_KEY=                  # set if the server requires a bearer token
LLM_JSON_MODE=true            # ask for strict JSON; auto-retries without it if rejected

# ── Embeddings (semantic search / Ask) ────────────────────────
# Defaults to LLM_BASE_URL if left blank. Set separately if embeddings run on a
# different server (e.g. a dedicated vLLM/TEI instance).
EMBED_BASE_URL=               # blank = same as LLM_BASE_URL
EMBED_MODEL=bge-m3            # blank = auto-pick the server's first model
EMBED_API_KEY=

# ── Docling (document parsing / OCR) ──────────────────────────
# Blank = run Docling in-process (bundled). Set to your running docling-serve
# base URL to offload parsing to that server (no docling models needed locally).
DOCLING_URL=                  # e.g. http://OFFICE-DOCLING:5001
DOCLING_API_KEY=
DOCLING_CONVERT_PATH=/v1/convert/file   # docling-serve convert endpoint
# Device for IN-PROCESS Docling only (ignored when DOCLING_URL is set):
#   auto = use GPU if present, auto-fall back to CPU on a CUDA out-of-memory error
#   cpu  = always CPU  (recommended on a single GPU shared with the LLM/Whisper —
#          Docling's layout model can otherwise exhaust VRAM and fail extraction)
#   cuda = force GPU
DOCLING_DEVICE=auto

# ── OCR policy ────────────────────────────────────────────────
# auto = OCR only scanned PDFs/images (digital PDFs skip OCR -> much faster)
# force = always OCR ;  off = never OCR
OCR_MODE=auto

# ── Qdrant (vector DB) ────────────────────────────────────────
# Blank QDRANT_URL = embedded on-disk store (zero setup, single process).
# Set QDRANT_URL to a running server (recommended for multi-user / many workers).
QDRANT_URL=                   # e.g. http://OFFICE-QDRANT:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=udaan_content

# ── AI extraction toggles ────────────────────────────────────
AI_ENABLED=true                 # master switch for document extraction
CONFIDENCE_THRESHOLD=0.7        # fields below this are flagged on the confirm screen

# ── Faster-Whisper STT (runs locally on the app PC) ───────────
# distil-large-v3 = English, near large-v3 accuracy, ~10x realtime on GPU.
# GPU needs only the NVIDIA driver (CUDA DLLs ship as wheels, auto-loaded).
# No GPU? -> WHISPER_DEVICE=cpu  WHISPER_COMPUTE_TYPE=int8
# Multilingual? -> WHISPER_MODEL=large-v3-turbo  WHISPER_LANGUAGE=
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE_TYPE=float16 # float16 (GPU) | int8 (CPU)
WHISPER_LANGUAGE=en          # language hint; empty = auto-detect
WHISPER_BEAM_SIZE=5          # 1 = fastest (greedy); 5 = more accurate (good on a dedicated GPU)

# ── Air-gapped / offline ML mode ──────────────────────────────
# true on a no-internet box: forces Whisper + in-process Docling to use ONLY the
# pre-staged local model caches (no "check for updates" calls that hang offline).
OFFLINE_MODE=false

# ── Redis (optional semantic cache; app runs fine without it) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# ── Proxy note (air-gapped LAN) ───────────────────────────────
# If this machine has a corporate HTTP(S)_PROXY set, add your in-network service
# hosts to NO_PROXY so calls to them don't get routed through the proxy (a common
# cause of spurious 401/timeout against LAN services). Example:
#   NO_PROXY=localhost,127.0.0.1,OFFICE-LLM,OFFICE-DOCLING,OFFICE-QDRANT

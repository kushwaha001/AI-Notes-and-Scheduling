front-end/deployment-package/
front-end/*.zip
# Environment — never commit real credentials
backend/.env
.env

# Uploaded files — keep folder structure, not content
backend/uploads/docs/*
backend/uploads/audio/*
backend/notes/*
!backend/uploads/docs/.gitkeep
!backend/uploads/audio/.gitkeep
!backend/notes/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Logs
*.log
*.err

# OS
.DS_Store
Thumbs.db

# Offline bundle artifacts (downloaded/transferred, not source)
offline/wheels/
offline/installers/
*.tar
front-end/dist/

# Cloudflare tunnel binary (download locally, don't commit)
cloudflared.exe

PROJECT_GUIDE.md
SHARING.md
share-with-tunnel.bat

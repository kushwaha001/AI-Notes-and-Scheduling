front-end/deployment-package/
front-end/*.zip
# Environment — never commit real credentials
backend/.env
.env

# Vector store (rebuilt from documents/notes)
backend/qdrant_data/

# Local backups
backend/backups/

# Test artifacts
backend/test_voice.wav

# Uploaded files — keep folder structure, not content
backend/uploads/docs/*
backend/uploads/audio/*
backend/notes/*
!backend/uploads/docs/.gitkeep
!backend/uploads/audio/.gitkeep
!backend/notes/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Logs
*.log
*.err

# OS
.DS_Store
Thumbs.db

# Offline bundle artifacts (downloaded/transferred, not source)
offline/wheels/
offline/wheels-gpu/
offline/wheels-bundle/
offline/models/
offline/installers/
offline/*.zip
offline/*.log
*.tar
front-end/dist/

# Keycloak server distribution (large; unzip locally, don't commit).
# The realm export + run script under keycloak/ ARE committed.
keycloak/dist/

# Cloudflare tunnel binary (download locally, don't commit)
cloudflared.exe

PROJECT_GUIDE.md
SHARING.md
share-with-tunnel.bat

# Personal learning documents (not part of the codebase)
*.docx

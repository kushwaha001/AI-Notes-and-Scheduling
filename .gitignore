!backend/uploads/audio/.gitkeep
!backend/notes/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Logs
*.log
*.err

# OS
.DS_Store
Thumbs.db
